    pass


# --------------------------------------------------------------------------------------------------------------------
def getAudioInfo():
    print("[AUDIO]")
    pwCliPresent = shutil.which('pw-cli')
    if pwCliPresent:
        rawOutput = subprocess.run(["pw-cli", "info", "0"], capture_output=True, text=True).stdout
        outputLines = rawOutput.splitlines()

        clockInfo = []
        for line in outputLines:
            if 'default.clock.rate ' in line or 'default.clock.quantum ' in line:
                parsedArray = line.split()
                clockInfo.append(int(parsedArray[-1][1:-1]))

        sampleRate = clockInfo[0]
        bufferSize = clockInfo[1]

        # formula: (buffer / sample rate) * 1000 = latency in ms
        audioLatency = round((bufferSize / sampleRate) * 1000, 2)

        print(f" Sample rate:   {sampleRate} hz")
        print(f" Buffer size:   {bufferSize}")
        print(f" Audio latency: {audioLatency}ms")
    else:
        print(' ERROR: pw-cli not found — cannot read audio configuration')
        print(' ERROR INFO: install pipewire-utils or make sure pw-cli is in your PATH')

# --------------------------------------------------------------------------------------------------------------------
def getCpuGovernor():
    print("[SYSTEM]")
    try:
        with open("/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor", "r") as cpuFile:
            governor = cpuFile.read().strip()

        if governor == "performance":
            print(f" CPU governor: {governor}")
        else:
            print(f" CPU governor: {governor}  ** set to 'performance' for lower latency")
    except FileNotFoundError:
        print(' ERROR: CPU governor info not found')
        print(' ERROR INFO: /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor does not exist on this system')

# --------------------------------------------------------------------------------------------------------------------
def getCompositor():
    compositor = (os.environ.get('XDG_CURRENT_DESKTOP') or
                  os.environ.get('DESKTOP_SESSION') or
                  'unknown')

    if os.environ.get('WAYLAND_DISPLAY'):
        displayServer = 'Wayland'
    elif os.environ.get('DISPLAY'):
        displayServer = 'Xorg'
    else:
        displayServer = 'unknown'

    print(f" Compositor:   {compositor} ({displayServer})  ** adds frame latency")

# --------------------------------------------------------------------------------------------------------------------
def getKernelInfo():
    isOptimal = False
    distro = "unknown"

    try:
        with open("/etc/os-release", "r") as distroInfoFile:
            distroInfoLines = distroInfoFile.read().splitlines()
            for line in distroInfoLines:
                parts = line.split("=")
                if len(parts) == 2:
                    key, value = parts[0].strip(), parts[1].strip()
                    if key == "ID":
                        distro = value
        if distro == "bazzite":
            isOptimal = True
    except FileNotFoundError:
        print(' ERROR: /etc/os-release not found — cannot detect distro')

    unamePresent = shutil.which('uname')
    if unamePresent:
        kernelVersion = subprocess.run(["uname", "-r"], capture_output=True, text=True).stdout.strip()
        kernelType = "standard"

        if "rt" in kernelVersion:
            kernelType = "realtime"
            isOptimal = True
        elif "cachyos" in kernelVersion:
            kernelType = "cachyos"
            isOptimal = True

        if isOptimal:
            print(f" Kernel: {kernelType} ({kernelVersion})")
        else:
            print(f" Kernel: {kernelType} ({kernelVersion})  ** consider a gaming kernel like cachyos or bazzite")
    else:
        print(' ERROR: uname not found — cannot detect kernel')
        print(' ERROR INFO: uname should be present on all Linux systems, something is very wrong')

# --------------------------------------------------------------------------------------------------------------------
def getOsuSettings():
    print('[OSU]')
    try:
        with open(os.path.expanduser("~/.local/share/osu/framework.ini"), "r") as frameworkIniFile:
            frameworkLines = frameworkIniFile.read().splitlines()
    except FileNotFoundError:
        print(' ERROR: framework.ini not found — is osu!lazer installed?')
        print(' ERROR INFO: expected at ~/.local/share/osu/framework.ini')
        return

    try:
        with open(os.path.expanduser("~/.local/share/osu/game.ini"), "r") as gameIniFile:
            gameLines = gameIniFile.read().splitlines()
    except FileNotFoundError:
        print(' ERROR: game.ini not found — is osu!lazer installed?')
        print(' ERROR INFO: expected at ~/.local/share/osu/game.ini')
        return

    frameSync = windowMode = renderer = executionMode = "unknown"
    for line in frameworkLines:
        parts = line.split(" = ")
        if len(parts) == 2:
            key, value = parts[0].strip(), parts[1].strip()
            if key == "FrameSync":
                frameSync = value
            elif key == "WindowMode":
                windowMode = value
            elif key == "Renderer":
                renderer = value
            elif key == "ExecutionMode":
                executionMode = value

    audioOffset = "unknown"
    for line in gameLines:
        parts = line.split(" = ")
        if len(parts) == 2:
            key, value = parts[0].strip(), parts[1].strip()
            if key == "AudioOffset":
                audioOffset = value


    if frameSync == "Unlimited":
        print(f" Frame sync:      {frameSync}")
    else:
        print(f" Frame sync:      {frameSync}  ** set to Unlimited for lowest latency")

    if windowMode == "Fullscreen":
        print(f" Window mode:     {windowMode}")
    else:
        print(f" Window mode:     {windowMode}  ** fullscreen reduces latency")

    if executionMode == "MultiThreaded":
        print(f" Execution mode:  {executionMode}")
    else:
        print(f" Execution mode:  {executionMode}  ** set to MultiThreaded to reduce audio latency")

    print(f" Renderer:        {renderer}")
    print(f" Audio offset:    {audioOffset}ms")

