def getRtkitStatus():
    systemctlPresent = shutil.which('systemctl')
    if not systemctlPresent:
        print(' rtkit:         ERROR: systemctl not found — cannot check rtkit status')
        return

    checkRtkit = subprocess.run(["systemctl", "is-active", "rtkit-daemon"], capture_output=True, text=True).stdout.strip()
    if checkRtkit != 'active':
        print(' rtkit:         not running  ** audio threads wont get realtime priority')
        return

    pgrepPresent = shutil.which('pgrep')
    if not pgrepPresent:
        print(' rtkit:         ERROR: pgrep not found — cannot find PipeWire process')
        return

    # PID of pipewire
    processIDPipeWire = subprocess.run(["pgrep", "-x", "pipewire"], capture_output=True, text=True).stdout.strip()

    if not processIDPipeWire:
        print(' rtkit:         ERROR: PipeWire process not found')
        return

    chrtPresent = shutil.which('chrt')
    if not chrtPresent:
        print(' rtkit:         ERROR: chrt not found — cannot check scheduling policy')
        return

    # SCHED_FIFO or SCHED_RR = realtime , otherwise SCHED_OTHER = normal
    # PipeWire uses realtime on THREADS not the main process
    schedulingInfo = subprocess.run(["ps", "-T", "-p", processIDPipeWire, "-o", "cls,rtprio"], capture_output=True, text=True).stdout

    rtConfirmed = False
    for line in schedulingInfo.splitlines():
        if 'FF' in line or 'RR' in line:
            rtConfirmed = True
            break

    if rtConfirmed:
        print(' rtkit:         active — PipeWire has realtime priority')
        return

    groupsPresent = shutil.which('groups')
    whoamiPresent = shutil.which('whoami')

    if groupsPresent and whoamiPresent:
        checkGroups = subprocess.run(["groups"], capture_output=True, text=True).stdout.strip()
        checkWhoami = subprocess.run(["whoami"], capture_output=True, text=True).stdout.strip()

        if 'rtkit' in checkGroups:
            print(' rtkit:         running but PipeWire is not realtime  ** check rtkit-daemon logs')
            print('                ** ensure audio is playing (e.g. osu!lazer) and try again')
        else:
            print(f' rtkit:         user \'{checkWhoami}\' not in rtkit group  ** run: sudo usermod -aG rtkit {checkWhoami}')



# --------------------------------------------------------------------------------------------------------------------
def getUsbAutosuspend():
    try:
        with open("/sys/module/usbcore/parameters/autosuspend", "r") as usbAutosuspendFile:
            autosuspendTimeout = int(usbAutosuspendFile.read().strip())
    except FileNotFoundError:
        print(' ERROR: USB autosuspend info not found')
        print(' ERROR INFO: /sys/module/usbcore/parameters/autosuspend does not exist')
        return
    except ValueError:
        print(' ERROR: could not parse USB autosuspend value')
        return

    if autosuspendTimeout == -1:
        print(" USB autosuspend:      disabled")
    elif autosuspendTimeout == 0:
        print(" USB autosuspend:      immediate")
    else:
        print(f" USB autosuspend:      {autosuspendTimeout}s")


# --------------------------------------------------------------------------------------------------------------------
def getOsuSettings():
    print('[OSU]')
    try:
        with open(os.path.expanduser("~/.local/share/osu/framework.ini"), "r") as frameworkIniFile:
            frameworkLines = frameworkIniFile.read().splitlines()
    except FileNotFoundError:
        print(' ERROR: framework.ini not found — is osu!lazer installed?')
        print(' ERROR INFO: expected at ~/.local/share/osu/framework.ini')
        return

    try:
        with open(os.path.expanduser("~/.local/share/osu/game.ini"), "r") as gameIniFile:
            gameLines = gameIniFile.read().splitlines()
    except FileNotFoundError:
        print(' ERROR: game.ini not found — is osu!lazer installed?')
        print(' ERROR INFO: expected at ~/.local/share/osu/game.ini')
        return

    frameSync = windowMode = renderer = executionMode = "unknown"
    for line in frameworkLines:
        parts = line.split(" = ")
        if len(parts) == 2:
            key, value = parts[0].strip(), parts[1].strip()
            if key == "FrameSync":
                frameSync = value
            elif key == "WindowMode":
                windowMode = value
            elif key == "Renderer":
                renderer = value
            elif key == "ExecutionMode":
                executionMode = value

    audioOffset = "unknown"
    for line in gameLines:
        parts = line.split(" = ")
        if len(parts) == 2:
            key, value = parts[0].strip(), parts[1].strip()
            if key == "AudioOffset":
                audioOffset = value

    if frameSync == "Unlimited":
        print(f" Frame sync:      {frameSync}")
    else:
        print(f" Frame sync:      {frameSync}  ** set to Unlimited for lowest latency")

    if windowMode == "Fullscreen":
        print(f" Window mode:     {windowMode}")
    else:
        print(f" Window mode:     {windowMode}  ** fullscreen reduces latency")

    if executionMode == "MultiThreaded":
        print(f" Execution mode:  {executionMode}")
    else:
        print(f" Execution mode:  {executionMode}  ** set to MultiThreaded to reduce audio latency")

    print(f" Renderer:        {renderer}")
    print(f" Audio offset:    {audioOffset}ms")



