#!/usr/bin/env python3
import subprocess
import os

print()
print('=== osu!lazer latency check ===\n')

def getAudioInfo():
    # query pipewire for system audio configuration
    rawOutput = subprocess.run(["pw-cli", "info", "0"], capture_output=True, text=True).stdout
    outputLines = rawOutput.splitlines()

    # extract sample rate and buffer size from output
    clockInfo = []
    for line in outputLines:
        if 'default.clock.rate ' in line or 'default.clock.quantum ' in line:
            parsedArray = line.split()
            clockInfo.append(int(parsedArray[-1][1:-1]))

    sampleRate = clockInfo[0]
    bufferSize = clockInfo[1]

    # formula: (buffer / sample rate) * 1000 = latency in ms
    audioLatency = round((bufferSize / sampleRate) * 1000, 2)

    print("[AUDIO]")
    print(f" Sample rate:   {sampleRate} hz")
    print(f" Buffer size:   {bufferSize}")
    print(f" Audio latency: {audioLatency}ms")

def getCpuGovernor():
    # read cpu frequency scaling governor from sysfs
    with open("/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor", "r") as cpuFile:
        governor = cpuFile.read().strip()

    # warn if not set to performance mode
    print("[SYSTEM]")
    if governor == "performance":
        print(f" CPU governor: {governor}")
    else:
        print(f" CPU governor: {governor}  ** use 'performance' for lower latency")

def getCompositor():
    # check multiple env variables since WMs may not set XDG_CURRENT_DESKTOP
    compositor = (os.environ.get('XDG_CURRENT_DESKTOP') or
                  os.environ.get('DESKTOP_SESSION') or
                  'unknown')

    # detect display server
    if os.environ.get('WAYLAND_DISPLAY'):
        displayServer = 'Wayland'
    elif os.environ.get('DISPLAY'):
        displayServer = 'Xorg'
    else:
        displayServer = 'unknown'

    # compositors always add frame latency
    print(f" Compositor:   {compositor} ({displayServer})  ** adds frame latency")

def getKernelInfo():
    kernelInfo = subprocess.run(["uname", "-r"], capture_output=True, text=True).stdout.strip()
    kernelType = "standard"
    isOptimal = False

    if "rt" in kernelInfo:
        kernelType = "realtime"
        isOptimal = True
    elif "bazzite" in kernelInfo:
        kernelType = "bazzite"
        isOptimal = True
    elif "cachy" in kernelInfo:
        kernelType = "cachy"
        isOptimal = True

    if isOptimal:
        print(f" Kernel: {kernelType}")
    else:
        print(f" Kernel: {kernelType}  ** consider a realtime or gaming kernel")

def getOsuSettings():
    # read osu framework and game config files
    with open(os.path.expanduser("~/.local/share/osu/framework.ini"), "r") as frameworkIniFile:
        frameworkLines = frameworkIniFile.read().splitlines()
    with open(os.path.expanduser("~/.local/share/osu/game.ini"), "r") as gameIniFile:
        gameLines = gameIniFile.read().splitlines()

    # parse settings from framework.ini
    frameSync = windowMode = renderer = executionMode = "unknown"
    for line in frameworkLines:
        parts = line.split(" = ")
        if len(parts) == 2:
            key, value = parts[0].strip(), parts[1].strip()
            if key == "FrameSync":       
                frameSync = value
            elif key == "WindowMode":    
                windowMode = value
            elif key == "Renderer":      
                renderer = value
            elif key == "ExecutionMode": 
                executionMode = value

    # parse audio offset from game.ini
    audioOffset = "unknown"
    for line in gameLines:
        parts = line.split(" = ")
        if len(parts) == 2:
            key, value = parts[0].strip(), parts[1].strip()
            if key == "AudioOffset": 
                audioOffset = value

    print("[OSU]")

    if frameSync == "Unlimited":
        print(f" Frame sync:      {frameSync}")
    else:
        print(f" Frame sync:      {frameSync}  ** set to Unlimited for lowest latency")

    if windowMode == "Fullscreen":
        print(f" Window mode:     {windowMode}")
    else:
        print(f" Window mode:     {windowMode}  ** fullscreen has lower latency")

    if executionMode == "MultiThreaded":
        print(f" Execution mode:  {executionMode}")
    else:
        print(f" Execution mode:  {executionMode}  ** MultiThreaded reduces audio latency")

    print(f" Renderer:        {renderer}")
    print(f" Audio offset:    {audioOffset}ms")



# function calls 
getAudioInfo()
print()
getCpuGovernor()
getCompositor() 
getKernelInfo() 
print()
getOsuSettings()
