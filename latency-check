#!/usr/bin/env python3
import subprocess
import os
import shutil

print()
print('=== osu!lazer latency check ===\n')


# --------------------------------------------------------------------------------------------------------------------
def getAudioInfo():
    print("[AUDIO]")
    if not shutil.which("pw-top"):
        print(" ERROR: pw-top not found")
        return

    result = subprocess.run(["pw-top", "-b", "--iterations=3"], capture_output=True, text=True) # timeout needed?
    lines = result.stdout.splitlines()

    # split the data in order to get the last most current snapshot of pw-top
    header = "S   ID  QUANT"
    snapshots = []
    current = []

    for line in lines:
        if line.startswith(header):
            if current:
                snapshots.append(current)
            current = []
        else:
            current.append(line)

    if current:
        snapshots.append(current)

    if not snapshots:
        print(" ERROR: no pw-top data")
        return

    last = snapshots[-1]

    # iter through and find info
    for line in last:
        parts = line.split()
        if not parts or parts[0] != "R":
            continue
        if len(parts) < 9:
            continue
        # skip followers (+ spotify etc)
        if "+" in parts[9:] or "=" in parts[9:]:
            continue

        try:
            bufferSize = int(parts[2])
            sampleRate = int(parts[3])
            waitRatio = float(parts[6])
            busyRatio = float(parts[7])
            xrunCount = int(parts[8])
            audioLatency = (bufferSize / sampleRate) * 1000
            cpuHeadroomPercent = (1.0 - busyRatio) * 100
            print(f" Sample rate:   {sampleRate} hz")
            print(f" Buffer size:   {bufferSize}")
            print(f" Audio latency: {audioLatency:.2f} ms")
            print(f" B(Busy)/Q:     {busyRatio:.2f} ({cpuHeadroomPercent:.0f}% headroom)")
            print(f" W(Wait)/Q:     {waitRatio:.2f}")
            print(f" XRUNs:         {xrunCount} (since start)")
            return
        except ValueError:
            continue

    print(" ERROR: no active audio node found")



# --------------------------------------------------------------------------------------------------------------------
def getCpuGovernor():
    print("[SYSTEM]")
    try:
        with open("/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor", "r") as cpuFile:
            governor = cpuFile.read().strip()

        if governor == "performance":
            print(f" CPU governor:  {governor}")
        else:
            print(f" CPU governor:  {governor}")
    except FileNotFoundError:
        print(' ERROR: CPU governor info not found')
        print(' ERROR INFO: /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor does not exist on this system')



# --------------------------------------------------------------------------------------------------------------------
def getCompositor():
    compositor = (os.environ.get('XDG_CURRENT_DESKTOP') or
                  os.environ.get('DESKTOP_SESSION') or
                  'unknown')

    if os.environ.get('WAYLAND_DISPLAY'):
        displayServer = 'Wayland'
    elif os.environ.get('DISPLAY'):
        displayServer = 'Xorg'
    else:
        displayServer = 'unknown'

    print(f" Compositor:    {compositor} ({displayServer})")



# --------------------------------------------------------------------------------------------------------------------
def getKernelInfo():
    isOptimal = False
    distro = "unknown"

    try:
        with open("/etc/os-release", "r") as distroInfoFile:
            distroInfoLines = distroInfoFile.read().splitlines()
            for line in distroInfoLines:
                parts = line.split("=")
                if len(parts) == 2:
                    key, value = parts[0].strip(), parts[1].strip()
                    if key == "ID":
                        distro = value
        if distro == "bazzite":
            isOptimal = True
    except FileNotFoundError:
        print(' ERROR: /etc/os-release not found — cannot detect distro')

    unamePresent = shutil.which('uname')
    if unamePresent:
        kernelVersion = subprocess.run(["uname", "-r"], capture_output=True, text=True).stdout.strip()
        kernelType = "standard"

        if "rt" in kernelVersion:
            kernelType = "realtime"
            isOptimal = True
        elif "cachyos" in kernelVersion:
            kernelType = "cachyos"
            isOptimal = True

        if isOptimal:
            print(f" Kernel:        {kernelType} ({kernelVersion})")
        else:
            print(f" Kernel:        {kernelType} ({kernelVersion})")
    else:
        print(' ERROR: uname not found — cannot detect kernel')
        print(' ERROR INFO: uname should be present on all Linux systems, something is very wrong')



# --------------------------------------------------------------------------------------------------------------------
def getKernelParams():
    try:
        with open("/proc/cmdline", "r") as bootParamsFile:
            bootParams = bootParamsFile.read().strip()
    except FileNotFoundError:
        print(" ERROR: /proc/cmdline not found — cannot read boot parameters")
        print(" ERROR INFO: this file should exist on all Linux systems")
        return

    params = {}
    for item in bootParams.split():
        if "=" in item:
            key, value = item.split("=", 1)
            params[key] = value
        else:
            params[item] = True

    if params.get("threadirqs"):
        print(" threadirqs:    enabled")
    else:
        print(" threadirqs:    not set")

    preempt = params.get("preempt")
    if preempt == "full":
        print(" preempt:       full")
    elif preempt is None:
        print(" preempt:       not set")
    else:
        print(f" preempt:      {preempt}")

    mitigations = params.get("mitigations")
    if mitigations == "off":
        print(" mitigations:   off")
    elif mitigations is None:
        print(" mitigations:   default (on)")
    else:
        print(f" mitigations:  {mitigations}")

    maxCstate = params.get("processor.max_cstate")
    if maxCstate == "1":
        print(" processor.max_cstate: 1")
    elif maxCstate is None:
        print(" processor.max_cstate: not set")
    else:
        print(f" processor.max_cstate: {maxCstate}")

    try:
        with open("/sys/devices/system/clocksource/clocksource0/current_clocksource", "r") as clocksourceFile:
            clocksourceContents = clocksourceFile.read().strip()
            print(f" active clocksource: {clocksourceContents}")
    except FileNotFoundError:
        print(' ERROR: clocksource info not found')
        print(' ERROR INFO: /sys/devices/system/clocksource/clocksource0/current_clocksource does not exist')
        return



